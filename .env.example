# QuickIn backend env — copy to .env and fill in. Set the same vars in Vercel.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
AUTH_SECRET=run `openssl rand -hex 32`

# SMTP for sign-up OTP emails (Namecheap Private Email shown; any SMTP works)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=you@your-domain.com
SMTP_PASS=your-mailbox-password
SMTP_FROM=you@your-domain.com

# Hardcoded admin login (username defaults to "admin")
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-admin-password

# --- Paymob (Accept) card gateway — payments live here, for web AND mobile ----
# Get these from the Paymob dashboard (Settings → API keys / Payment Integrations).
PAYMOB_SECRET_KEY=egy_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_PUBLIC_KEY=egy_pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMOB_INTEGRATION_ID=000000
PAYMOB_HMAC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API key (Account Info → API Key) — used to confirm a payment's authoritative status via Paymob's
# API (the webhook verifies payments this way instead of via the opaque Unified-Checkout HMAC).
PAYMOB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional — defaults to https://accept.paymob.com (KSA: https://ksa.paymob.com, UAE: https://uae.paymob.com)
# PAYMOB_BASE=https://accept.paymob.com

# Allowlist for the web "return to site" redirect after checkout (comma-separated origins).
# The web app passes its own /reservations URL; only matching origins are honoured (no open redirect).
# Leave unset to keep mobile/web on the backend's own return page.
WEB_APP_URL=https://quickin-frontend.vercel.app
